{
  "example-scope": {
    "organization": {
      "id": "pd_organization",
      "input_descriptors": [
        {
          "id": "id_org_cred",
          "constraints": {
            "fields": [
              {
                "path": ["$.type"],
                "filter": {
                  "type": "string",
                  "const": "NutsOrganizationCredential"
                }
              }
            ]
          }
        }
      ]
    },
    "service_provider": {
      "id": "pd_service_provider",
      "input_descriptors": [
        {
          "id": "id_sp_cred",
          "constraints": {
            "fields": [
              {
                "path": ["$.type"],
                "filter": {
                  "type": "string",
                  "const": "ServiceProviderCredential"
                }
              }
            ]
          }
        }
      ]
    },
    "user": {
      "id": "pd_user",
      "input_descriptors": [
        {
          "id": "id_user_cred",
          "constraints": {
            "fields": [
              {
                "path": ["$.type"],
                "filter": {
                  "type": "string",
                  "const": "EmployeeCredential"
                }
              }
            ]
          }
        }
      ]
    }
  }
}
